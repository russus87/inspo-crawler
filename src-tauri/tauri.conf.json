{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inspo Crawler",
  "version": "0.1.0",
  "identifier": "com.russus.inspocrawler",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Inspo Crawler",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Graphics",
    "shortDescription": "Design inspiration crawler",
    "longDescription": "Search UI and design inspiration across Pinterest, Dribbble, Behance, Unsplash and Are.na, then save the images you like — one by one or in bulk.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
